# Environment Variables for FlowSync AI
# Copy this file to .env and fill in your values.
# All settings are optional — the app runs fully on mocks when not provided.

# ── Core ──────────────────────────────────────────────────────────────────────
# Set to 'true' during local development only.
# In production this must be 'false'.
DEBUG=true

# Show /docs and /redoc. Set to 'false' in production.
DOCS_ENABLED=true

# ── Gemini (required for AI explanations and chatbot) ─────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=5

# ── Google Cloud (leave empty to use in-memory mocks) ─────────────────────────
GCP_PROJECT_ID=
FIRESTORE_ENABLED=false
BIGQUERY_ENABLED=false
MAPS_ENABLED=false

# ── Security (production only) ────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Example: ALLOWED_ORIGINS_RAW=https://flowsync.run.app,https://admin.flowsync.run.app
# Leave empty in debug mode — wildcard CORS is used automatically.
ALLOWED_ORIGINS_RAW=
